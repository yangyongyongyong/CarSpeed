<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <FrameLayout
        android:id="@+id/overlayPanel"
        android:layout_width="340dp"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/overlayContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/overlay_panel_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/rowTopBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvClose"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/overlay_chip_dark_bg"
                    android:gravity="center"
                    android:text="×"
                    android:textColor="#EAF3FF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvOverlayTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="驾驶 HUD"
                        android:textColor="#F7FAFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDragHandle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="拖动移动 · 靠边收起"
                        android:textColor="#B8C8E6"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnScaleDown"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/overlay_chip_dark_bg"
                    android:gravity="center"
                    android:text="-"
                    android:textColor="#78C8FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnScaleUp"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/overlay_chip_dark_bg"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#78C8FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSpeedCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="5.5"
                    android:background="@drawable/overlay_info_chip_bg"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvMaxSpeedLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="最高速度"
                        android:textColor="#F7FAFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMaxSpeedValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0.0"
                        android:textColor="#7BE0C3"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMaxSpeedUnit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="km/h"
                        android:textColor="#9AC8B9"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMaxSpeedTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="峰值时间 --:--:--"
                        android:textColor="#B8C8E6"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="4.5"
                    android:background="@drawable/overlay_chip_dark_bg"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvCurrentSpeedLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="当前速度"
                        android:textColor="#F7FAFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentSpeedValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="start"
                        android:maxLines="2"
                        android:lineSpacingExtra="0dp"
                        android:text="0.0"
                        android:textColor="#79C7FF"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentSpeedUnit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="km/h"
                        android:textColor="#9DB4D8"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGpsSatelliteCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="GPS卫星：--"
                        android:textColor="#B8C8E6"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutDetailSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:id="@+id/vDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#335F7AA6" />

                <TextView
                    android:id="@+id/tvTrendLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="最近 60 秒速度趋势"
                    android:textColor="#F7FAFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <com.thomas.carspeed.SpeedTrendView
                    android:id="@+id/speedTrendView"
                    android:layout_width="match_parent"
                    android:layout_height="126dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/overlay_chip_dark_bg" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/overlay_info_chip_bg"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tvWaitLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="静止等待"
                            android:textColor="#B8C8E6"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvAccelValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="00:00:00"
                            android:textColor="#F7FAFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/overlay_info_chip_bg"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tvTripDurationLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="驾驶时长"
                            android:textColor="#B8C8E6"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvHeadingValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="00:00:00"
                            android:textColor="#F7FAFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/overlayBubble"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="center"
        android:background="@drawable/overlay_bubble_bg"
        android:gravity="center"
        android:text="0"
        android:textColor="#F7FAFF"
        android:textSize="19sp"
        android:textStyle="bold"
        android:visibility="gone" />

</FrameLayout>
